APP_NAME="Royal Harvest"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://royalharvest.co.tz

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database ---
# Production: MySQL. For quick local dev you may switch to DB_CONNECTION=sqlite.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=royalharvest_company
DB_USERNAME=royalharvest_company
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@royalharvest.co.tz"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# --- Cross-site link + business info ---
SALON_URL=https://pixiesbridalsaloon.royalharvest.co.tz
COMPANY_PHONE="+255 759 389 897"
COMPANY_EMAIL=info@royalharvest.co.tz
COMPANY_ADDRESS="Arusha, Tanzania"
# WhatsApp number in international format, digits only (e.g. 255759389897)
COMPANY_WHATSAPP=255759389897
COMPANY_INSTAGRAM=
COMPANY_FACEBOOK=
COMPANY_LINKEDIN=

# --- Analytics (optional) ---
ANALYTICS_GA_ID=
