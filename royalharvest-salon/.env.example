APP_NAME="Pixies Bridal Saloon"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://pixiesbridalsaloon.royalharvest.co.tz

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database ---
# Production: MySQL. For quick local dev you may switch to DB_CONNECTION=sqlite.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=royalharvest_salon
DB_USERNAME=royalharvest_salon
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to your domain in production for cookie scoping, e.g. .royalharvest.co.tz
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@pixiesbridal.co.tz"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# --- Cross-site link + business info ---
COMPANY_URL=https://royalharvest.co.tz
SALON_PHONE="+255 759 389 897"
SALON_EMAIL=info@pixiesbridal.co.tz
SALON_ADDRESS="Arusha, Tanzania"
# WhatsApp number in international format, digits only (e.g. 255759389897)
SALON_WHATSAPP=255759389897
SALON_INSTAGRAM=
SALON_FACEBOOK=
SALON_TIKTOK=

# --- Payments (Snippe) ---
SNIPPE_BASE_URL=https://api.snippe.sh/v1
SNIPPE_API_KEY=
SNIPPE_WEBHOOK_URL=https://pixiesbridalsaloon.royalharvest.co.tz/webhooks/snippe
SNIPPE_WEBHOOK_SECRET=
SNIPPE_CURRENCY=TZS
BOOKING_DEPOSIT_PERCENT=10

# --- SMS (Beem Africa) ---
BEEM_BASE_URL=https://apisms.beem.africa/v1/send
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_SENDER_ID=SwalaTech

# --- Analytics (optional) ---
# Google Analytics measurement ID (G-XXXXXXX) or leave blank to disable
ANALYTICS_GA_ID=
